# ChapterOPS — environment template.
#
# Copy this file to `.env` (gitignored) and fill in your Supabase project's
# values. NEVER commit real keys. The anon key is public-ish (RLS protects data)
# but should still not live in git; the service_role key must NEVER be committed.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Multiple environments (alpha vs staging) ─────────────────────────────────
# The app reads whichever project these two values point at. To work with more
# than one Supabase project, keep a separate local file per project, e.g.:
#
#   .env.alpha.local     ->  live / alpha project URL + anon key
#   .env.staging.local   ->  staging project URL + anon key
#
# Switch projects by copying the one you want into `.env`, then restart with a
# cleared cache:  npx expo start -c
#
# All `.env` variants are gitignored except THIS template (.env.example).
# Do not create the *.local files with real keys until you intend to use them,
# and never commit them.
