# ChapterOPS — environment template.
#
# Copy this file to `.env` (gitignored) and fill in your Supabase project's
# values. NEVER commit real keys. The anon key is public-ish (RLS protects data)
# but should still not live in git; the service_role key must NEVER be committed.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Feature flags (fail-closed; default OFF) ─────────────────────────────────
# Each flag is ON only when set to the exact string "true". Leaving them unset,
# blank, or "false" keeps the app in the single-org sandbox (committed default).
# Do NOT set these to true in this template or in any committed file — only in a
# local flag-on profile (see below).
EXPO_PUBLIC_AUTH_ENABLED=false
EXPO_PUBLIC_ORG_SCOPED_DATA=false

# ── Multiple environments (alpha vs staging) ─────────────────────────────────
# The app reads whichever project these two values point at. To work with more
# than one Supabase project, keep a separate local file per project, e.g.:
#
#   .env.alpha.local     ->  live / alpha project URL + anon key       (flags OFF)
#   .env.staging.local   ->  staging project URL + anon key            (flags OFF)
#
# For a FLAG-ON build (auth + org-scoped data enabled) against a project, keep a
# separate flag-on profile that adds the two flag vars set to "true", e.g.:
#
#   .env.alpha.flagon.local     ->  alpha URL/key   + EXPO_PUBLIC_AUTH_ENABLED=true
#                                                    + EXPO_PUBLIC_ORG_SCOPED_DATA=true
#   .env.staging.flagon.local   ->  staging URL/key + the same two =true lines
#
# Switch profiles by copying the one you want into `.env`, then restart with a
# cleared cache:  npx expo start -c
#
# All `.env` variants are gitignored except THIS template (.env.example).
# Do not create the *.local files with real keys until you intend to use them,
# and never commit them. Never set the flag vars to "true" in a committed file.
