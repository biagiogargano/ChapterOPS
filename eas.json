{
  "cli": {
    "version": ">= 5.9.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "ios": { "simulator": false },
      "env": {
        "EXPO_PUBLIC_AUTH_ENABLED": "true",
        "EXPO_PUBLIC_ORG_SCOPED_DATA": "true"
      }
    },
    "alpha": {
      "autoIncrement": true,
      "environment": "production",
      "ios": { "simulator": false },
      "env": {
        "EXPO_PUBLIC_AUTH_ENABLED": "true",
        "EXPO_PUBLIC_ORG_SCOPED_DATA": "true"
      }
    }
  },
  "submit": {
    "alpha": {
      "ios": {
        "ascAppId": "6773430324",
        "appleTeamId": "6NPWF9RRGX"
      }
    }
  }
}
